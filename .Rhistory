TAB_DIR   <- file.path(BASE_DIR, "output", "tabelas")
GRAF_DIR  <- file.path(BASE_DIR, "output", "graficos")
dir.create(TAB_DIR,  recursive = TRUE, showWarnings = FALSE)
dir.create(GRAF_DIR, recursive = TRUE, showWarnings = FALSE)
cat("=== Análise de Correlação ===\n\n")
df <- read.csv(INPUT_CSV, stringsAsFactors = FALSE)
df$data <- as.Date(df$data)
n <- nrow(df)
cat("Observações carregadas:", n, "\n\n")
x_petr4 <- df$retorno_petr4
x_ibov  <- df$retorno_ibov
x_brent <- df$retorno_brent
x_dolar <- df$retorno_dolar
cat("--- 1. Verificação de Normalidade ---\n\n")
vars_lista <- list(
retorno_petr4 = x_petr4,
retorno_ibov  = x_ibov,
retorno_brent = x_brent,
retorno_dolar = x_dolar
)
# 1.1 Shapiro-Wilk
cat("Teste de Shapiro-Wilk:\n")
shapiro_res <- lapply(names(vars_lista), function(nome) {
sw <- shapiro.test(vars_lista[[nome]])
data.frame(variavel = nome,
W        = round(sw$statistic, 4),
p_value  = round(sw$p.value,   4),
normal   = ifelse(sw$p.value > 0.05, "Sim", "Nao"))
})
shapiro_tab <- do.call(rbind, shapiro_res)
print(shapiro_tab)
write.csv(shapiro_tab, file.path(TAB_DIR, "shapiro_wilk.csv"), row.names = FALSE)
# 1.2 QQ Plots
for (nome in names(vars_lista)) {
arquivo <- file.path(GRAF_DIR, paste0("qqplot_", nome, ".png"))
png(arquivo, width = 800, height = 600)
qqnorm(vars_lista[[nome]], main = paste("QQ Plot —", nome),
col = "steelblue", pch = 16)
qqline(vars_lista[[nome]], col = "red", lwd = 2)
dev.off()
cat("QQ Plot salvo:", arquivo, "\n")
}
cat("\n")
# Decisão sobre método
todos_normais <- all(shapiro_tab$p_value > 0.05)
cat(if (todos_normais)
"Todas as variáveis passaram em Shapiro-Wilk (p > 0,05). Usa-se PEARSON.\n"
else
"Ao menos uma variável rejeitou normalidade. Calcula-se PEARSON e SPEARMAN (ambos reportados).\n")
pearson_3formas <- function(x, y, label_x = "X", label_y = "Y") {
cat("\n--- Pearson:", label_x, "×", label_y, "---\n")
# ---- Forma 1: Z-scores ----
zx <- (x - mean(x)) / sd(x)
zy <- (y - mean(y)) / sd(y)
r1 <- sum(zx * zy) / (length(x) - 1)
cat(sprintf("  Forma 1 (Z-score):            r = %.6f\n", r1))
# ---- Forma 2: Desvios em relação à média ----
dx <- x - mean(x)
dy <- y - mean(y)
r2 <- sum(dx * dy) / sqrt(sum(dx^2) * sum(dy^2))
cat(sprintf("  Forma 2 (Desvios da média):   r = %.6f\n", r2))
# ---- Forma 3: Somas brutas ----
n   <- length(x)
num <- n * sum(x * y) - sum(x) * sum(y)
den <- sqrt((n * sum(x^2) - sum(x)^2) * (n * sum(y^2) - sum(y)^2))
r3  <- num / den
cat(sprintf("  Forma 3 (Somas brutas):       r = %.6f\n", r3))
# ---- Validação com cor() ----
r_nativo <- cor(x, y)
cat(sprintf("  cor() nativo:                 r = %.6f\n", r_nativo))
# Verifica equivalência (tolerância numérica)
equiv <- all(abs(c(r1, r2, r3) - r_nativo) < 1e-8)
cat(sprintf("  Todas as formas equivalentes: %s\n", ifelse(equiv, "SIM", "VERIFICAR")))
return(r_nativo)
