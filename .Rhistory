}
pearson_3formas <- function(x, y, label_x = "X", label_y = "Y") {
cat("\n--- Pearson:", label_x, "×", label_y, "---\n")
# ---- Forma 1: Z-scores ----
zx <- (x - mean(x)) / sd(x)
zy <- (y - mean(y)) / sd(y)
r1 <- sum(zx * zy) / (length(x) - 1)
cat(sprintf("  Forma 1 (Z-score):            r = %.6f\n", r1))
# ---- Forma 2: Desvios em relação à média ----
dx <- x - mean(x)
dy <- y - mean(y)
r2 <- sum(dx * dy) / sqrt(sum(dx^2) * sum(dy^2))
cat(sprintf("  Forma 2 (Desvios da média):   r = %.6f\n", r2))
# ---- Forma 3: Somas brutas ----
n   <- length(x)
num <- n * sum(x * y) - sum(x) * sum(y)
den <- sqrt((n * sum(x^2) - sum(x)^2) * (n * sum(y^2) - sum(y)^2))
r3  <- num / den
cat(sprintf("  Forma 3 (Somas brutas):       r = %.6f\n", r3))
# ---- Validação com cor() ----
r_nativo <- cor(x, y)
cat(sprintf("  cor() nativo:                 r = %.6f\n", r_nativo))
# Verifica equivalência (tolerância numérica)
equiv <- all(abs(c(r1, r2, r3) - r_nativo) < 1e-8)
cat(sprintf("  Todas as formas equivalentes: %s\n", ifelse(equiv, "SIM", "VERIFICAR")))
