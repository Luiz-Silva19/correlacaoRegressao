}
r_petr_ibov  <- pearson_3formas(x_petr4, x_ibov,  "PETR4", "IBOV")
r_petr_brent <- pearson_3formas(x_petr4, x_brent, "PETR4", "BRENT")
r_petr_dolar <- pearson_3formas(x_petr4, x_dolar, "PETR4", "DOLAR")
erencia_pearson <- function(r, n, label, alpha = 0.05) {
cat(sprintf("\n--- Inferência Pearson: %s ---\n", label))
gl   <- n - 2
t_obs <- r * sqrt(gl) / sqrt(1 - r^2)
t_crit <- qt(1 - alpha / 2, df = gl)
p_val  <- 2 * pt(-abs(t_obs), df = gl)
cat(sprintf("  r = %.4f\n", r))
cat(sprintf("  n = %d  |  gl = %d\n", n, gl))
cat(sprintf("  t calculado = %.4f\n", t_obs))
cat(sprintf("  t crítico   = %.4f (alpha = %.2f, bilateral)\n", t_crit, alpha))
cat(sprintf("  p-value     = %.6f\n", p_val))
cat(sprintf("  Decisão H0  : %s\n",
ifelse(abs(t_obs) > t_crit, "REJEITA H0 — correlação significativa",
"NÃO rejeita H0")))
# IC 95% via Transformação Z de Fisher
z_r   <- 0.5 * log((1 + r) / (1 - r))   # Fisher Z
se_z  <- 1 / sqrt(n - 3)
z_crit <- qnorm(1 - alpha / 2)
li_z  <- z_r - z_crit * se_z
ls_z  <- z_r + z_crit * se_z
li_r  <- (exp(2 * li_z) - 1) / (exp(2 * li_z) + 1)
ls_r  <- (exp(2 * ls_z) - 1) / (exp(2 * ls_z) + 1)
cat(sprintf("  IC 95%% Fisher Z: [%.4f ; %.4f]\n", li_r, ls_r))
data.frame(
par       = label,
r_pearson = round(r,     4),
t_obs     = round(t_obs, 4),
gl        = gl,
p_value   = round(p_val, 6),
ic_li     = round(li_r,  4),
ic_ls     = round(ls_r,  4)
)
}
inf_ibov  <- inferencia_pearson(r_petr_ibov,  n, "PETR4 x IBOV")
inf_brent <- inferencia_pearson(r_petr_brent, n, "PETR4 x BRENT")
inf_dolar <- inferencia_pearson(r_petr_dolar, n, "PETR4 x DOLAR")
# ---------------------------------------------------------------------------
# 4. Correlação de Spearman
# ---------------------------------------------------------------------------
spearman_manual <- function(x, y, label) {
cat(sprintf("\n--- Spearman: %s ---\n", label))
# Ranqueia as variáveis
rx <- rank(x)
ry <- rank(y)
# Calcula rs pela fórmula de desvios (equivalente a Pearson nos ranks)
drx <- rx - mean(rx)
dry <- ry - mean(ry)
rs_manual <- sum(drx * dry) / sqrt(sum(drx^2) * sum(dry^2))
rs_nativo <- cor(x, y, method = "spearman")
cat(sprintf("  rs manual = %.6f\n", rs_manual))
cat(sprintf("  rs nativo = %.6f\n", rs_nativo))
cat(sprintf("  Equivalentes: %s\n",
ifelse(abs(rs_manual - rs_nativo) < 1e-8, "SIM", "VERIFICAR")))
return(rs_nativo)
}
rs_ibov  <- spearman_manual(x_petr4, x_ibov,  "PETR4 x IBOV")
rs_brent <- spearman_manual(x_petr4, x_brent, "PETR4 x BRENT")
rs_dolar <- spearman_manual(x_petr4, x_dolar, "PETR4 x DOLAR")
# ---------------------------------------------------------------------------
# 5. Tabela Final de Correlações
# ---------------------------------------------------------------------------
cat("\n=== Tabela Final de Correlações ===\n")
tabela_corr <- data.frame(
variavel    = c("PETR4 x IBOV", "PETR4 x BRENT", "PETR4 x DOLAR"),
pearson     = c(round(r_petr_ibov, 4), round(r_petr_brent, 4), round(r_petr_dolar, 4)),
spearman    = c(round(rs_ibov, 4),     round(rs_brent, 4),     round(rs_dolar, 4)),
p_value     = c(inf_ibov$p_value,      inf_brent$p_value,      inf_dolar$p_value),
ic_95_li    = c(inf_ibov$ic_li,        inf_brent$ic_li,        inf_dolar$ic_li),
ic_95_ls    = c(inf_ibov$ic_ls,        inf_brent$ic_ls,        inf_dolar$ic_ls)
)
print(tabela_corr)
write.csv(tabela_corr,
file = file.path(TAB_DIR, "tabela_correlacoes.csv"),
row.names = FALSE)
cat("\nTabela salva em:", file.path(TAB_DIR, "tabela_correlacoes.csv"), "\n")
# ---------------------------------------------------------------------------
# 6. Gráfico de Dispersão (PETR4 × cada variável)
# ---------------------------------------------------------------------------
pares <- list(
list(x = x_ibov,  nome = "retorno_ibov",  label = "IBOV"),
list(x = x_brent, nome = "retorno_brent", label = "Brent"),
list(x = x_dolar, nome = "retorno_dolar", label = "Dólar")
)
for (p in pares) {
r_val <- round(cor(x_petr4, p$x), 4)
graf  <- ggplot(data.frame(x = p$x, y = x_petr4),
aes(x = x, y = y)) +
geom_point(color = "steelblue", alpha = 0.7, size = 2.5) +
geom_smooth(method = "lm", se = TRUE, color = "red", linewidth = 1) +
labs(title    = paste("PETR4 ×", p$label),
subtitle = paste("r de Pearson =", r_val),
x        = paste("Retorno", p$label, "(%)"),
y        = "Retorno PETR4 (%)") +
theme_minimal(base_size = 13)
arquivo <- file.path(GRAF_DIR, paste0("dispersao_petr4_", p$nome, ".png"))
ggsave(arquivo, plot = graf, width = 8, height = 6, dpi = 150)
cat("Gráfico salvo:", arquivo, "\n")
}
cat("\n=== Análise de Correlação concluída ===\n")
